# Anthropic API key — required for AI branch generation
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Supabase — required for the full platform (auth, persistence, analytics)
# Leave blank to run in demo-only mode (no auth, no persistence)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Perspective API — optional, adds toxicity detection layer
# Without this, content is still protected by input filter + system prompt + Zod schema
# For production with children, strongly recommended
# Get yours at: https://developers.perspectiveapi.com/
PERSPECTIVE_API_KEY=

# Content standards — controls market-specific content filtering
# Values: international (strictest, default) | uae | eu | us | custom
CONTENT_STANDARDS=international

# Site password — optional, gates the entire site behind a password
# Useful for pre-launch or invite-only access
SITE_PASSWORD=
